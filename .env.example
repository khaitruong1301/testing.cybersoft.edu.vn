# Sao chép file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.

# --- Cơ sở dữ liệu (SQLite — triển khai hiện tại) ---
# Dev: file trong thư mục prisma/
DATABASE_URL="file:./dev.db"
# Production trên server: dùng đường dẫn TUYỆT ĐỐI, NẰM NGOÀI thư mục deploy để không mất khi redeploy:
# DATABASE_URL="file:C:/ProgramData/testing/prod.db"
# Khi scale lớn → Postgres: đổi provider = "postgresql" trong prisma/schema.prisma rồi:
# DATABASE_URL="postgresql://user:password@host:5432/cybersoft_tester?schema=public"

# --- Bảo mật phiên (JWT admin + ký cookie) — chuỗi ngẫu nhiên >= 32 ký tự ---
AUTH_SECRET="doi-thanh-chuoi-ngau-nhien-toi-thieu-32-ky-tu"

# --- Tài khoản admin khởi tạo (seed tạo lần đầu) ---
ADMIN_EMAIL="admin@cybersoft.edu.vn"
ADMIN_PASSWORD="Admin@12345"

# --- URL công khai của site (dùng cho watermark, canonical...) ---
NEXT_PUBLIC_SITE_URL="https://testing.cybersoft.edu.vn"

# --- Gửi email mã đăng nhập OTP (SendGrid) — BẮT BUỘC để học viên cũ tự nhận mã ---
# Lấy API key trong SendGrid → dán vào đây trên .env của SERVER (KHÔNG commit).
SENDGRID_API_KEY=""
# Email người gửi PHẢI được xác thực (Single Sender / Domain Authentication) trong SendGrid:
SENDGRID_FROM_EMAIL="noreply@cybersoft.edu.vn"
SENDGRID_FROM_NAME="CyberSoft Tester"
