# Sao chép file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.

# --- Cơ sở dữ liệu ---
# Production: Postgres (VPS local / Neon / Supabase). Bật connection pooling khi chạy serverless.
DATABASE_URL="postgresql://user:password@localhost:5432/cybersoft_tester?schema=public"
# Dev nhanh bằng SQLite: đổi provider trong prisma/schema.prisma sang "sqlite" rồi dùng:
# DATABASE_URL="file:./dev.db"

# --- Bảo mật phiên (JWT admin + ký cookie) — chuỗi ngẫu nhiên >= 32 ký tự ---
AUTH_SECRET="doi-thanh-chuoi-ngau-nhien-toi-thieu-32-ky-tu"

# --- Tài khoản admin khởi tạo (seed tạo lần đầu) ---
ADMIN_EMAIL="admin@cybersoft.edu.vn"
ADMIN_PASSWORD="Admin@12345"

# --- URL công khai của site (dùng cho watermark, canonical...) ---
NEXT_PUBLIC_SITE_URL="https://testing.cybersoft.edu.vn"
