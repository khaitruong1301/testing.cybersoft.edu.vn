// CyberSoft Tester — data model
// -------------------------------------------------------------------
// TRIỂN KHAI HIỆN TẠI: provider = "sqlite" (giống site anh em entrance —
// gọn, tự chứa, không cần cài DB server). DATABASE_URL trỏ tới file .db:
//   - Dev:  DATABASE_URL="file:./dev.db"          (→ prisma/dev.db)
//   - Prod: DATABASE_URL="file:C:/ProgramData/testing/prod.db"  (nằm NGOÀI thư
//           mục deploy để không bị mất khi redeploy)
// Đồng bộ + nạp:
//   npx prisma db push   (đồng bộ schema)
//   npm run db:seed      (nạp/cập nhật nội dung — KHÔNG phá dữ liệu)
// KHI SCALE LỚN → Postgres: đổi provider = "postgresql" và DATABASE_URL trỏ
//   Postgres (Neon/Supabase/VPS, nên bật pooling). Schema tương thích cả hai.
// -------------------------------------------------------------------

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------- Students & Access ----------------

// STUDENT_TYPE: "OLD" (đã/đang học) or "UNREGISTERED" (chưa đăng ký)
model Student {
  id            String    @id @default(cuid())
  name          String
  email         String
  phone         String
  type          String    @default("OLD") // OLD | UNREGISTERED
  registered    Boolean   @default(false) // đổi trạng thái chưa->đã đăng ký

  // Access window: counted from the FIRST successful login (firstLoginAt).
  firstLoginAt  DateTime?
  accessExpires DateTime? // computed on first login (firstLoginAt + duration)
  active        Boolean   @default(true)

  code          AccessCode? @relation(fields: [codeId], references: [id])
  codeId        String?     @unique

  sessions      Session[]
  attempts      Attempt[]
  views         ArticleView[]
  bookmarks     Bookmark[]
  votes         Vote[]
  comments      Comment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([phone])
  @@index([type])
}

// 6-char alphanumeric access codes generated by admin (from Excel import).
model AccessCode {
  id         String   @id @default(cuid())
  code       String   @unique // 6 chars, no ambiguous letters
  // Snapshot of the roster row this code was generated for.
  name       String
  email      String
  phone      String
  type       String   @default("OLD") // OLD | UNREGISTERED
  batch      String?  // import batch label (e.g. "2026-07 K21")
  usedBy     Student?
  createdAt  DateTime @default(now())

  @@index([email])
  @@index([batch])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([studentId])
}

// ---------------- Admin ----------------

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String   @default("Administrator")
  createdAt    DateTime @default(now())
}

// Key/value settings (access durations, quiz sizes, etc.)
model Setting {
  key   String @id
  value String
}

// ---------------- Content: Tab 1 — Learning materials ----------------

// TAB kinds: DOCS (tài liệu), INTERVIEW (luyện phỏng vấn)
model Category {
  id          String    @id @default(cuid())
  tab         String    @default("DOCS") // DOCS | INTERVIEW
  slug        String    @unique
  // Trilingual titles/descriptions stored as JSON strings {vi,en,ja}
  title       String
  description String    @default("{}")
  icon        String    @default("book")
  order       Int       @default(0)
  articles    Article[]
  questions   InterviewQuestion[]
  createdAt   DateTime  @default(now())

  @@index([tab])
}

model Article {
  id           String        @id @default(cuid())
  slug         String?       @unique // khóa ổn định để cập nhật tại chỗ (upsert) mà KHÔNG mất bookmark/lượt đọc
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId   String
  title        String        // JSON {vi,en,ja}
  summary      String        @default("{}") // short text under card (JSON)
  body         String        @default("{}") // long description / tóm tắt (JSON)
  cover        String        @default("") // avatar/thumbnail url, inline SVG, or emoji
  tags         String        @default("[]") // JSON array of {k,vi,en,ja,g} clickable tags
  level        String        @default("advanced") // "beginner" (Dành cho người mới) | "advanced" (Thực chiến nâng cao)
  compliant    Boolean       @default(true) // ĐẠT chuẩn Testing_BaiViet (≥12 chương/mục lục + 3 ngôn ngữ Việt/Anh/Nhật dịch thật). Bài không đạt bị ẩn.
  viewCount    Int           @default(0) // lượt view
  readCount    Int           @default(0) // số người đăng ký đọc
  published    Boolean       @default(true)
  order        Int           @default(0)
  upvotes      Int           @default(0) // daily.dev-style score (denormalised)
  downvotes    Int           @default(0)
  pages        ArticlePage[]
  views        ArticleView[]
  bookmarks    Bookmark[]
  votes        Vote[]
  comments     Comment[]
  createdAt    DateTime      @default(now())

  @@index([categoryId])
  @@index([published])
}

// Upvote / downvote per student per article (daily.dev style).
model Vote {
  id        String   @id @default(cuid())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  value     Int      // 1 = upvote, -1 = downvote
  createdAt DateTime @default(now())

  @@unique([articleId, studentId])
  @@index([articleId])
}

// Public comments (visible to everyone; only logged-in students can post).
model Comment {
  id         String   @id @default(cuid())
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId  String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  String
  authorName String
  body       String
  createdAt  DateTime @default(now())

  @@index([articleId])
}

// Paged, view-only "PDF-like" viewer.
// kind "text": rich page rendered from `content` (trilingual block JSON).
// kind "image": page is an image (`image`).
model ArticlePage {
  id        String  @id @default(cuid())
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  order     Int     @default(0)
  kind      String  @default("text") // text | image
  content   String  @default("{}") // JSON {vi:[blocks], en:[...], ja:[...]}
  image     String  @default("") // image url / data (kind=image)
  caption   String  @default("{}") // JSON {vi,en,ja}

  @@index([articleId])
}

// Tracks unique detailed views per student (for readCount / lượt xem chi tiết).
model ArticleView {
  id        String   @id @default(cuid())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  createdAt DateTime @default(now())

  @@unique([articleId, studentId])
  @@index([articleId])
}

// Saved articles ("bookmark") with an optional personal note, per student.
model Bookmark {
  id        String   @id @default(cuid())
  article   Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  articleId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId String
  note      String   @default("") // ghi chú cá nhân của học viên
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([articleId, studentId])
  @@index([studentId])
  @@index([articleId])
}

// ---------------- Content: Tab 2/3 — Interview questions ----------------

// kind: MCQ (trắc nghiệm) | ESSAY (tự luận) | SCENARIO (tình huống)
model InterviewQuestion {
  id          String   @id @default(cuid())
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String
  kind        String   @default("MCQ")
  prompt      String   // JSON {vi,en,ja}
  options     String   @default("[]") // JSON array of {vi,en,ja} for MCQ
  answer      String   @default("") // MCQ: correct index; ESSAY/SCENARIO: model answer / keywords JSON
  explanation String   @default("{}") // JSON {vi,en,ja}
  difficulty  Int      @default(1)
  createdAt   DateTime @default(now())

  @@index([categoryId])
  @@index([kind])
}

// A practice or mock attempt with auto-grading result.
model Attempt {
  id         String   @id @default(cuid())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  studentId  String
  mode       String   @default("PRACTICE") // PRACTICE | MOCK
  categoryId String?
  payload    String   @default("{}") // JSON: questions + user answers
  score      Float    @default(0)
  maxScore   Float    @default(0)
  durationSec Int     @default(0)
  createdAt  DateTime @default(now())

  @@index([studentId])
  @@index([mode])
}
